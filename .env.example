OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional. If unset, the healer uses deterministic local hash embeddings
# for runbook retrieval so the demo can still start without network secrets.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

AUDIT_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healer
SQLITE_PATH=./healer_audit.db

PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
CHROMA_DB_DIR=./chroma_db
RUNBOOKS_DIR=infra/runbooks

CONFIDENCE_THRESHOLD=0.75
ALLOWED_AUTO_ACTIONS=["RESTART_CONTAINER","NOTIFY_ONLY"]
REQUIRE_HUMAN_APPROVAL=false
