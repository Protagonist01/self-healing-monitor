{
  "title": "Self-Healing Monitor",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Incidents Received",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(incident_intake_total)" }
      ]
    },
    {
      "type": "stat",
      "title": "Resolved",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(incident_resolved_total)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Demo Service Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (service, status) (rate(http_requests_total[1m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Leaky Service Memory",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "container_memory_working_set_bytes{container=\"leaky_service\"}" }
      ]
    }
  ]
}
